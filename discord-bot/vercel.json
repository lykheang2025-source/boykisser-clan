{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/interaction",
      "dest": "/api/interaction.py"
    },
    {
      "src": "/api/sync",
      "dest": "/api/sync.py"
    },
    {
      "src": "/",
      "dest": "/api/interaction.py"
    }
  ]
}